<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <HediffDef>
    <defName>CZH_ZombieRot</defName>
    <hediffClass>HediffWithComps</hediffClass>
    <label>zombie rot</label>
    <description>This pawn is an undead zombie. Its body is decayed, slow, and unnaturally persistent unless the head is damaged.</description>
    <isBad>true</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <tendable>false</tendable>
    <makesAlert>false</makesAlert>
    <comps>
      <li Class="CustomizableZombieHorde.HediffCompProperties_ZombieRot" />
      <li Class="HediffCompProperties_VerbGiver">
        <verbs>
          <li>
            <verbClass>CustomizableZombieHorde.ZombieVerb_GrabberTongue</verbClass>
            <label>tongue lash</label>
            <range>12</range>
            <warmupTime>0.15</warmupTime>
            <defaultCooldownTime>4.8</defaultCooldownTime>
            <minRange>2.2</minRange>
            <hasStandardCommand>false</hasStandardCommand>
            <defaultProjectile>CZH_GrabberTongueProjectile</defaultProjectile>
            <forcedMissRadius>0</forcedMissRadius>
            <accuracyTouch>999</accuracyTouch>
            <accuracyShort>999</accuracyShort>
            <accuracyMedium>999</accuracyMedium>
            <accuracyLong>999</accuracyLong>
            <targetParams>
              <canTargetPawns>true</canTargetPawns>
              <canTargetLocations>false</canTargetLocations>
              <canTargetBuildings>false</canTargetBuildings>
              <canTargetSelf>false</canTargetSelf>
            </targetParams>
          </li>
          <li>
            <verbClass>CustomizableZombieHorde.ZombieVerb_MeleeAttack</verbClass>
            <label>bite</label>
            <range>1</range>
            <meleeDamageDef>Bite</meleeDamageDef>
            <meleeDamageBaseAmount>3</meleeDamageBaseAmount>
            <defaultCooldownTime>3.4</defaultCooldownTime>
          </li>
          <li>
            <verbClass>CustomizableZombieHorde.ZombieVerb_MeleeAttack</verbClass>
            <label>scratch</label>
            <range>1</range>
            <meleeDamageDef>Scratch</meleeDamageDef>
            <meleeDamageBaseAmount>1</meleeDamageBaseAmount>
            <defaultCooldownTime>2.7</defaultCooldownTime>
          </li>
        </verbs>
      </li>
    </comps>
    <stages>
      <li>
        <label>rotting</label>
        <painFactor>0.2</painFactor>
        <capMods>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.45</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.25</offset>
          </li>
        </capMods>
        <statOffsets>
          <MoveSpeed>-1.35</MoveSpeed>
          <MeleeDamageFactor>-0.35</MeleeDamageFactor>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
