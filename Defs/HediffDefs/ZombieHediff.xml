            <capacity>Moving</capacity>
            <offset>-1.00</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-1.00</offset>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

