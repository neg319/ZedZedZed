  <HediffDef>
    <defName>CZH_ZombieSickness</defName>
    <hediffClass>CustomizableZombieHorde.Hediff_ZombieInfection</hediffClass>
    <label>zombie infection</label>
    <description>Contact with sick zombie blood or a filthy zombie bite has left this pawn infected. Bite caused infections can begin in a specific limb and may be stopped if that limb is amputated before the infection turns terminal. The first four stages are treatable. Terminal stages begin at 60 percent. At 80 percent the victim falls into a living coma. If they survive to 99 percent, the infection completes the turn and converts the living pawn into a colony lurker through the same path used by zombie bile injection. If the pawn dies earlier from other injuries, the corpse stays dead.</description>
    <isBad>true</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <tendable>true</tendable>
    <makesAlert>true</makesAlert>
    <initialSeverity>0.01</initialSeverity>
    <maxSeverity>1.0</maxSeverity>
    <stages>
      <li>
        <minSeverity>0.01</minSeverity>
        <label>Fresh Bite (Treatable)</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.01</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.02</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.10</minSeverity>
        <label>Itchy Bite (Treatable)</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.03</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.05</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.30</minSeverity>
        <label>Infected Bite (Treatable)</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.06</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.10</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.50</minSeverity>
        <label>Strange Flu (Treatable)</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.10</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.16</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.60</minSeverity>
        <label>Infected Bloodstream (Terminal)</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.18</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.28</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.70</minSeverity>
        <label>Necrosis and Dementia (Terminal)</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.32</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.45</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.80</minSeverity>
        <label>Coma (Terminal)</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-1.00</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-1.00</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.90</minSeverity>
        <label>Transformation (Reanimated)</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-1.00</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-1.00</offset>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>
