      <li Class="CustomizableZombieHorde.HediffCompProperties_DamageOverTime">
        <tickInterval>300</tickInterval>
        <damageAmount>1.1</damageAmount>
        <damageDef>Burn</damageDef>
        <severityLossPerTick>0.06</severityLossPerTick>
      </li>
    </comps>
    <stages>
      <li>
        <label>corroding</label>
      </li>
    </stages>
  </HediffDef>

