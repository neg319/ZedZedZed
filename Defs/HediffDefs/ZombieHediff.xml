        <maxWakeTicks>24000</maxWakeTicks>
        <healIntervalTicks>180</healIntervalTicks>
        <healAmount>1.35</healAmount>
      </li>
    </comps>
    <stages>
      <li>
        <label>dead state</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-2.00</offset>
          </li>
