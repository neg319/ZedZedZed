  <HediffDef>
    <defName>CZH_ZombieSickness</defName>
    <hediffClass>CustomizableZombieHorde.Hediff_ZombieInfection</hediffClass>
    <label>zombie infection</label>
    <description>Contact with sick zombie blood has left this pawn infected. The infection worsens day by day, reaches a terminal point at 90% where treatment no longer works and the pawn dies, and if the pawn dies earlier from other injuries the infection still keeps climbing from that exact percentage after death. At 100%, the infection becomes the permanent Reanimated state. Once reanimated, the corpse checks every in game hour and has a 50% chance to rise whenever the head and skull are still intact.</description>
    <isBad>true</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <tendable>true</tendable>
    <makesAlert>true</makesAlert>
    <initialSeverity>0.20</initialSeverity>
    <maxSeverity>1.0</maxSeverity>
    <stages>
      <li>
        <label>fresh infection</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.03</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.06</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.3143</minSeverity>
        <label>worsening</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.06</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.10</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.4286</minSeverity>
        <label>advancing</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.09</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.14</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.5429</minSeverity>
        <label>serious</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.12</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.18</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.6572</minSeverity>
        <label>grave</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.16</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.24</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.7715</minSeverity>
        <label>critical</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.21</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.31</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.90</minSeverity>
        <label>terminal</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.28</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.40</offset>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>
  <HediffDef>
    <defName>CZH_ZombieReanimated</defName>
    <hediffClass>CustomizableZombieHorde.Hediff_ZombieInfection</hediffClass>
    <label>reanimated</label>
    <description>This pawn completed the zombie infection and entered the permanent Reanimated state. This final state cannot be cured. Once dead, it keeps checking every in game hour and has a 50% chance to rise whenever the head and skull are still intact.</description>
    <isBad>true</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <tendable>false</tendable>
    <makesAlert>false</makesAlert>
    <initialSeverity>1.0</initialSeverity>
    <maxSeverity>1.0</maxSeverity>
    <stages>
      <li>
        <label>reanimated</label>
      </li>
    </stages>
  </HediffDef>
  <HediffDef>
    <defName>CZH_ZombieAcidCorrosion</defName>
    <hediffClass>HediffWithComps</hediffClass>
    <label>zombie acid corrosion</label>
    <description>Caustic zombie acid is still eating at the flesh and causing ongoing burn damage.</description>
    <isBad>true</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <tendable>false</tendable>
    <makesAlert>false</makesAlert>
    <initialSeverity>0.35</initialSeverity>
    <maxSeverity>1.0</maxSeverity>
