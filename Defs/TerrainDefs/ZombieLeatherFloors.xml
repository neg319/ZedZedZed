      <Beauty>1</Beauty>
      <Cleanliness>0</Cleanliness>
      <Flammability>1.1</Flammability>
    </statBases>
  </TerrainDef>

  <TerrainDef ParentName="Floor">
    <defName>CZH_MottledHideFloor</defName>
    <label>mottled hide floor</label>
    <description>A grim leather floor with muted green gray staining and dark skin like blotches. It blends the palette of several strains into one seamless surface.</description>
    <texturePath>Terrain/MottledHideFloor</texturePath>
    <renderPrecedence>211</renderPrecedence>
    <constructEffect>ConstructDirt</constructEffect>
