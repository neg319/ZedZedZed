  <ThingDef ParentName="CZH_ZombieGraveBase">
    <defName>CZH_Grave_Biter</defName>
    <label>biter grave</label>
    <description>A grave that keeps spawning biters until destroyed.</description>
    <comps>
      <li Class="CustomizableZombieHorde.CompProperties_ZombieGraveSpawner">
        <compClass>CustomizableZombieHorde.CompZombieGraveSpawner</compClass>
        <variant>Biter</variant>
        <initialBurstCount>4</initialBurstCount>
        <minBurstCount>1</minBurstCount>
        <maxBurstCount>2</maxBurstCount>
        <minRespawnTicks>1800</minRespawnTicks>
        <maxRespawnTicks>3600</maxRespawnTicks>
      </li>
    </comps>
  </ThingDef>

