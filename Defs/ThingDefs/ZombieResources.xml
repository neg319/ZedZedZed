<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef Name="CZH_ResourceBase" Abstract="True">
    <thingClass>ThingWithComps</thingClass>
    <label>unspecified resource</label>
    <category>Item</category>
    <stackLimit>75</stackLimit>
    <altitudeLayer>Item</altitudeLayer>
    <alwaysHaulable>true</alwaysHaulable>
    <drawGUIOverlay>true</drawGUIOverlay>
    <rotatable>false</rotatable>
    <selectable>true</selectable>
    <useHitPoints>true</useHitPoints>
    <pathCost>15</pathCost>
    <comps>
      <li Class="CompProperties_Forbiddable" />
    </comps>
  </ThingDef>

  <ThingDef ParentName="CZH_ResourceBase">
    <defName>CZH_RottenFlesh</defName>
    <label>rotten flesh</label>
    <description>Rotten zombie meat. It never spoils.</description>
    <graphicData>
      <texPath>Things/Item/Resource/RottenFlesh</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <tradeability>Sellable</tradeability>
    <stackLimit>75</stackLimit>
    <thingCategories>
      <li>Items</li>
    </thingCategories>
    <statBases>
      <MarketValue>0.55</MarketValue>
      <Mass>0.02</Mass>
      <MaxHitPoints>40</MaxHitPoints>
      <Flammability>0.35</Flammability>
      <Nutrition>0.05</Nutrition>
    </statBases>
    <socialPropernessMatters>true</socialPropernessMatters>
    <ingestible>
      <foodType>Meat</foodType>
      <preferability>RawBad</preferability>
    </ingestible>
  </ThingDef>

  <ThingDef ParentName="LeatherBase">
    <defName>CZH_RottenLeather</defName>
    <label>rotten leather</label>
    <description>Hide taken from zombie remains.</description>
    <graphicData>
      <texPath>Things/Item/Resource/RottenLeather</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <tradeability>Sellable</tradeability>
    <stackLimit>75</stackLimit>
    <statBases>
      <MarketValue>1.05</MarketValue>
      <Mass>0.03</Mass>
      <Flammability>0.25</Flammability>
      <Beauty>-2</Beauty>
    </statBases>
    <stuffProps>
      <stuffAdjective>rotten leather</stuffAdjective>
      <categories>
        <li>Leathery</li>
        <li>CZH_RottenLeathery</li>
      </categories>
      <commonality>0.20</commonality>
      <color>(0.32,0.23,0.18)</color>
      <statFactors>
        <ArmorRating_Blunt>0.75</ArmorRating_Blunt>
        <ArmorRating_Sharp>0.80</ArmorRating_Sharp>
        <MaxHitPoints>0.75</MaxHitPoints>
        <MarketValue>0.85</MarketValue>
        <Beauty>-1.0</Beauty>
      </statFactors>
    </stuffProps>
  </ThingDef>

  <ThingDef ParentName="CZH_ResourceBase">
    <defName>CZH_ZombieJerky</defName>
    <label>zombie jerky</label>
    <description>Preserved zombie meat. It lasts indefinitely but offers little nutrition.</description>
    <graphicData>
      <texPath>Things/Item/Resource/ZombieJerky</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <tradeability>Sellable</tradeability>
    <stackLimit>75</stackLimit>
    <thingCategories>
      <li>Items</li>
    </thingCategories>
    <statBases>
      <MarketValue>1.25</MarketValue>
      <Mass>0.02</Mass>
      <MaxHitPoints>35</MaxHitPoints>
      <Flammability>0.20</Flammability>
      <Nutrition>0.04</Nutrition>
    </statBases>
    <socialPropernessMatters>true</socialPropernessMatters>
    <ingestible>
      <foodType>Meat, Processed</foodType>
      <preferability>MealAwful</preferability>
    </ingestible>
  </ThingDef>


  <ThingDef ParentName="CZH_ResourceBase">
    <defName>CZH_GoldTooth</defName>
    <label>gold tooth</label>
    <description>A gold tooth pulled from zombie remains.</description>
    <graphicData>
      <texPath>Things/Item/Resource/GoldTooth</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <tradeability>Sellable</tradeability>
    <stackLimit>75</stackLimit>
    <thingCategories>
      <li>ResourcesRaw</li>
      <li>Items</li>
    </thingCategories>
    <statBases>
      <MarketValue>10</MarketValue>
      <Mass>0.03</Mass>
      <Beauty>4</Beauty>
      <Flammability>0.00</Flammability>
    </statBases>
    <stuffProps>
      <categories>
        <li>Metallic</li>
      </categories>
      <commonality>0.00</commonality>
      <color>(1.0,0.84,0.22)</color>
      <statFactors>
        <WorkToMake>1.00</WorkToMake>
        <MarketValue>1.00</MarketValue>
        <MaxHitPoints>1.00</MaxHitPoints>
        <Mass>1.00</Mass>
        <Beauty>1.00</Beauty>
      </statFactors>
    </stuffProps>
  </ThingDef>

  <ThingDef ParentName="BaseFilth">
    <defName>CZH_Filth_ZombieBlood</defName>
    <label>zombie blood</label>
    <description>Undead blood.</description>
    <statBases>
      <Beauty>-30</Beauty>
      <Cleanliness>-10</Cleanliness>
    </statBases>
    <graphicData>
      <texPath>Things/Filth/ZombieBloodVariants</texPath>
      <graphicClass>Graphic_Random</graphicClass>
      <shaderType>Transparent</shaderType>
    </graphicData>
    <filth>
      <cleaningWorkToReduceThickness>70</cleaningWorkToReduceThickness>
      <canFilthAttach>true</canFilthAttach>
      <disappearsInDays>14~15</disappearsInDays>
      <rainWashes>true</rainWashes>
    </filth>
  </ThingDef>

  <ThingDef ParentName="BaseFilth">
    <defName>CZH_Filth_SickZombieBlood</defName>
    <label>black zombie blood</label>
    <description>Blood from a diseased zombie.</description>
    <statBases>
      <Beauty>-30</Beauty>
      <Cleanliness>-10</Cleanliness>
    </statBases>
    <graphicData>
      <texPath>Things/Filth/SickZombieBloodVariants</texPath>
      <graphicClass>Graphic_Random</graphicClass>
      <shaderType>Transparent</shaderType>
    </graphicData>
    <filth>
      <cleaningWorkToReduceThickness>70</cleaningWorkToReduceThickness>
      <canFilthAttach>true</canFilthAttach>
      <disappearsInDays>14~15</disappearsInDays>
      <rainWashes>true</rainWashes>
    </filth>
  </ThingDef>

  <ThingDef ParentName="BaseFilth">
    <defName>CZH_Filth_ZombieAcid</defName>
    <label>zombie acid</label>
    <description>Caustic fluid from an exploding boomer.</description>
    <statBases>
      <Beauty>-30</Beauty>
      <Cleanliness>-12</Cleanliness>
    </statBases>
    <graphicData>
      <texPath>Things/Filth/ZombieAcidVariants</texPath>
      <graphicClass>Graphic_Random</graphicClass>
      <shaderType>Transparent</shaderType>
    </graphicData>
    <filth>
      <cleaningWorkToReduceThickness>70</cleaningWorkToReduceThickness>
      <canFilthAttach>true</canFilthAttach>
      <disappearsInDays>10~12</disappearsInDays>
      <rainWashes>true</rainWashes>
    </filth>
  </ThingDef>
</Defs>
