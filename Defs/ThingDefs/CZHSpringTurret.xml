<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef ParentName="BuildingBase">
    <defName>CZH_Turret_Spring</defName>
    <label>spring turret</label>
    <description>A compact automatic turret built around a simple spring drive and a stripped down targeter. It does not need power or ammo, fires a steady shot every second, and sits in the security tab beside the rest of your colony defenses.</description>
    <thingClass>RimWorld.Building_TurretGun</thingClass>
    <category>Building</category>
    <drawerType>MapMeshAndRealTime</drawerType>
    <tickerType>Normal</tickerType>
    <altitudeLayer>Building</altitudeLayer>
    <castEdgeShadows>true</castEdgeShadows>
    <fillPercent>0.25</fillPercent>
    <rotatable>false</rotatable>
    <size>(1,1)</size>
    <graphicData>
      <texPath>Things/Building/Security/CZHSpringTurretBase</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1,1)</drawSize>
      <shadowData>
        <volume>(0.35, 0.2, 0.35)</volume>
        <offset>(0,0,-0.04)</offset>
      </shadowData>
    </graphicData>
    <uiIconPath>Things/Building/Security/CZHSpringTurretBase</uiIconPath>
    <costList>
      <Steel>100</Steel>
      <ComponentIndustrial>2</ComponentIndustrial>
    </costList>
    <designationCategory>Security</designationCategory>
    <placeWorkers>
      <li>RimWorld.PlaceWorker_ShowTurretRadius</li>
    </placeWorkers>
    <passability>PassThroughOnly</passability>
    <pathCost>30</pathCost>
    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
    <leaveResourcesWhenKilled>true</leaveResourcesWhenKilled>
    <building>
      <turretGunDef>CZH_Gun_SpringTurret</turretGunDef>
      <ai_combatDangerous>true</ai_combatDangerous>
      <isEdifice>true</isEdifice>
      <buildingTags>
        <li>Security</li>
      </buildingTags>
    </building>
    <comps>
      <li Class="CompProperties_Forbiddable" />
      <li Class="RimWorld.CompProperties_TurretGun" />
    </comps>
    <statBases>
      <MaxHitPoints>180</MaxHitPoints>
      <WorkToBuild>12000</WorkToBuild>
      <Mass>28</Mass>
      <MarketValue>280</MarketValue>
      <Flammability>0.65</Flammability>
    </statBases>
  </ThingDef>

  <ThingDef>
    <defName>CZH_Gun_SpringTurret</defName>
    <label>spring turret gun</label>
    <description>An internal gun definition used by the spring turret.</description>
    <thingClass>Verse.ThingWithComps</thingClass>
    <category>Item</category>
    <techLevel>Industrial</techLevel>
    <drawGUIOverlay>false</drawGUIOverlay>
    <drawerType>RealtimeOnly</drawerType>
    <graphicData>
      <texPath>Things/Building/Security/CZHSpringTurretTop</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1,1)</drawSize>
      <shaderType>Cutout</shaderType>
    </graphicData>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>false</hasStandardCommand>
        <warmupTime>0.18</warmupTime>
        <defaultProjectile>CZH_Bullet_SpringTurret</defaultProjectile>
        <range>28.9</range>
        <ticksBetweenBurstShots>60</ticksBetweenBurstShots>
        <burstShotCount>1</burstShotCount>
        <soundCast>Shot_Autopistol</soundCast>
        <muzzleFlashScale>5</muzzleFlashScale>
      </li>
    </verbs>
    <comps>
      <li Class="RimWorld.CompProperties_Equippable" />
    </comps>
    <statBases>
      <Mass>1</Mass>
      <MarketValue>0</MarketValue>
      <AccuracyTouch>1.00</AccuracyTouch>
      <AccuracyShort>0.98</AccuracyShort>
      <AccuracyMedium>0.94</AccuracyMedium>
      <AccuracyLong>0.90</AccuracyLong>
      <RangedWeapon_Cooldown>1.00</RangedWeapon_Cooldown>
    </statBases>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>CZH_Bullet_SpringTurret</defName>
    <label>spring turret round</label>
    <graphicData>
      <texPath>Things/Projectile/Bullet_Small</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <projectile>
      <damageDef>Bullet</damageDef>
      <damageAmountBase>9</damageAmountBase>
      <speed>55</speed>
    </projectile>
  </ThingDef>
</Defs>
